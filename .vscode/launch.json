{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "PacManOS (QEMU GDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/out/debug/engineos/engineos.elf",
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "miDebuggerServerAddress": "localhost:1234",
      "targetArchitecture": "x86",
      "stopAtEntry": false,
      "externalConsole": false,
      "preLaunchTask": "qemu:gdb-stub",
      "setupCommands": [
        {
          "description": "Enable Intel disassembly syntax",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        },
        {
          "description": "Accept breakpoints before game symbols are loaded",
          "text": "-gdb-set breakpoint pending on",
          "ignoreFailures": false
        },
        {
          "description": "Load game module symbol helper",
          "text": "-interpreter-exec console \"source ${workspaceFolder}/scripts/gdb_load_game_syms.py\"",
          "ignoreFailures": false
        }
      ]
    }
  ]
}
