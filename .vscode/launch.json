{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "PacManOS (QEMU GDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/out/debug/iso/boot/gameos.elf",
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "miDebuggerServerAddress": "localhost:1234",
      "targetArchitecture": "x86",
      "stopAtEntry": true,
      "externalConsole": false,
      "preLaunchTask": "qemu-gdb",
      "setupCommands": [
        {
          "description": "Enable Intel disassembly syntax",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
