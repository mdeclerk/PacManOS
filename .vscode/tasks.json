      "label": "qemu:gdb-stub",
      "type": "shell",
      "command": "./buildenv.sh",
      "args": ["qemu-gdb-stub"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^:::never:::",
          "endsPattern": "^>>> QEMU GDB"
        }
      }
    },
